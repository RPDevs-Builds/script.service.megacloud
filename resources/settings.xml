<?xml version="1.0" encoding="UTF-8"?>
<settings version="1">
    <section id="script.service.megacloud">
        <category id="general" label="30000">
            <group id="1" label="30000">
                <setting id="port" type="integer" label="30001">
                    <level>0</level>
                    <default>4000</default>
                    <constraints>
                        <minimum>1024</minimum>
                        <maximum>65535</maximum>
                        <step>1</step>
                    </constraints>
                    <control type="slider" format="integer"/>
                </setting>
                <setting id="autostart" type="boolean" label="30002">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="keys_url" type="string" label="30003">
                    <level>1</level>
                    <default>https://raw.githubusercontent.com/yogesh-hacker/MegacloudKeys/refs/heads/main/keys.json</default>
                    <control type="edit" format="string"/>
                </setting>
            </group>
            <group id="2" label="30004">
                <setting id="fs_enable" type="boolean" label="30005">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="fs_url" type="string" label="30006">
                    <level>0</level>
                    <default>http://localhost:8191/v1</default>
                    <control type="edit" format="string"/>
                    <dependencies>
                        <dependency setting="fs_enable" expression="true"/>
                    </dependencies>
                </setting>
                <setting id="fs_timeout" type="integer" label="30007">
                    <level>1</level>
                    <default>30</default>
                    <constraints>
                        <minimum>5</minimum>
                        <maximum>120</maximum>
                        <step>5</step>
                    </constraints>
                    <control type="slider" format="integer"/>
                    <dependencies>
                        <dependency setting="fs_enable" expression="true"/>
                    </dependencies>
                </setting>
            </group>
        </category>
    </section>
</settings>

